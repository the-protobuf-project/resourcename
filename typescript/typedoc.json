{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": ["./index.ts"],
	"tsconfig": "./tsconfig.json",
	"out": "docs/api",
	"readme": "./README.md",
	"name": "@the-protobuf-project/resourcename",
	"skipErrorChecking": true,
	"excludePrivate": true,
	"excludeProtected": true,
	"validation": {
		"notExported": true,
		"invalidLink": true,
		"notDocumented": false
	}
}
